# Pfad zur ffmpeg-Executable.
# Wenn ffmpeg im PATH liegt, reicht einfach "ffmpeg" (Windows/macOS/Linux).
# Beispiele:
#   Windows: C:/tools/ffmpeg/bin/ffmpeg.exe
#   macOS:   /opt/homebrew/bin/ffmpeg
#   Linux:   /usr/bin/ffmpeg
FFMPEG_PATH=ffmpeg

# Optional: Pfad zu ffprobe. Wird sonst aus FFMPEG_PATH abgeleitet.
# FFPROBE_PATH=ffprobe

# Port des Backends
PORT=3000

# Optional: Schriftdatei für das Zeit-Overlay (oben rechts).
# Wird sonst plattformabhängig automatisch gewählt (Consolas/Menlo/DejaVu Sans Mono).
# Beispiele:
#   Windows: C:/Windows/Fonts/consola.ttf
#   macOS:   /System/Library/Fonts/Menlo.ttc
#   Linux:   /usr/share/fonts/truetype/dejavu/DejaVuSansMono.ttf
# OVERLAY_FONTFILE=/usr/share/fonts/truetype/dejavu/DejaVuSansMono.ttf
