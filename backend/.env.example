# Pfad zur ffmpeg-Executable (z. B. C:\tools\ffmpeg\bin\ffmpeg.exe).
# Wenn ffmpeg im PATH liegt, reicht einfach "ffmpeg".
FFMPEG_PATH=ffmpeg

# Optional: Pfad zu ffprobe. Wird sonst aus FFMPEG_PATH abgeleitet.
# FFPROBE_PATH=ffprobe

# Port des Backends
PORT=3000

# Optional: Schriftdatei für das Zeit-Overlay (oben rechts).
# Standard: C:/Windows/Fonts/consola.ttf
# OVERLAY_FONTFILE=C:/Windows/Fonts/arial.ttf
